<script>
function checkSimilarity(){
  const code1 = document.getElementById("code1").value.trim();
  const code2 = document.getElementById("code2").value.trim();
  const language = document.getElementById("language").value;

  if (!code1 || !code2){
    alert("Please enter code in both fields");
    return;
  }

  const formData = new FormData();
  formData.append("code1", code1);
  formData.append("code2", code2);
  formData.append("language", language);

  fetch("/check", {
    method: "POST",
    body: formData
  })
  .then(res => {
    if (!res.ok) throw new Error("Error checking similarity. Make sure you are logged in.");
    return res.json();
  })
  .then(data => {
    if (data.error){
      alert(data.error);
      return;
    }
    document.getElementById("result").innerText = "Similarity: " + data.similarity + "%";
    document.getElementById("bar").style.width = data.similarity + "%";
    document.getElementById("extra").innerHTML =
      "Plagiarism Level: " + data.level + "<br>" +
      "Matched Tokens: " + data.matched_tokens + "<br>" +
      "Code1 Length: " + data.code1_length + " tokens<br>" +
      "Code2 Length: " + data.code2_length + " tokens<br>" +
      "Language: " + data.language;
  })
  .catch(err => alert(err.message));
}
</script>



